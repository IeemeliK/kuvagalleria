# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kuvagalleria
HOST=db
PORT=5432

COOKIESTORE_SECRET=change-me-to-a-random-secret

# Uploads (defaults to ./data/uploads so only set for custom path)
UPLOADS_DIR=./data/uploads

# pgAdmin (only used in dev)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Goose
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:postgres@localhost:5432/kuvagalleria
GOOSE_MIGRATION_DIR=./migrations
